<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>BBBI Community</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/components.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>

  <%- include('../partials/nav') %>

  <main id="main">
    <div class="container">
      <div class="login-container">
        <h1>Admin Login</h1>

        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
          <div class="alert alert-error">
            <ul>
              <% errors.forEach(err => { %>
                <li><%= err.msg %></li>
              <% }); %>
            </ul>
          </div>
        <% } %>

        <form method="POST" class="login-form">
          <div class="form-group">
            <label for="username">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              required
              autofocus
            >
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
            >
          </div>

          <button type="submit" class="btn btn-primary btn-large">Sign In</button>
        </form>

        <p class="login-footer">
          <a href="/">← Back to Home</a>
        </p>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
