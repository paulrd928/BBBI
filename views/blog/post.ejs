<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>BBBI Community</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;600;700&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/components.css">
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>

  <%- include('../partials/nav') %>

  <main id="main">
    <div class="container">
      <div class="post-container">
    <article class="post-article">
      <header class="post-header">
        <h1><%= post.title %></h1>
        <div class="post-meta">
          <span class="badge badge--<%= post.author_type %>">
            <%= post.author_type === 'member' ? 'Community Member' : 'Caregiver' %>
          </span>
          <span class="post-author">By <%= post.author_name %></span>
          <span class="post-date">
            <%= new Date(post.created_at).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            }) %>
          </span>
        </div>
      </header>

      <% if (post.video_url) { %>
        <figure class="post-media">
          <video controls aria-label="Video message from <%= post.author_name %>">
            <source src="<%= post.video_url %>" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        </figure>
      <% } %>

      <div class="post-content">
        <%- post.content %>
      </div>

      <footer class="post-footer">
        <nav class="post-nav">
          <a href="/blog" class="btn btn-outline">← Back to Stories</a>
          <% if (post.author_type === 'caregiver') { %>
            <a href="/caregivers" class="btn btn-outline">More from Caregivers</a>
          <% } %>
        </nav>
      </footer>
    </article>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
