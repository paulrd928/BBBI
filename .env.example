PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-characters

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=BBBI Community <your@gmail.com>

# Optional: Cloudinary (for video hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Database path (use /data/bbbi.db on Railway with a Volume)
DB_PATH=./database/bbbi.db
